{
  "name": "asset-manager",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "asset-manager",
      "version": "0.0.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "apps/api": {
      "name": "@asset-manager/api",
      "version": "0.0.0"
    },
    "apps/web": {
      "name": "@asset-manager/web",
      "version": "0.0.0"
    },
    "node_modules/@asset-manager/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@asset-manager/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@asset-manager/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/shared": {
      "name": "@asset-manager/shared",
      "version": "0.0.0"
    }
  }
}
