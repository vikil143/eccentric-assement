{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@asset-manager/shared": ["../../packages/shared/src/index.ts"],
      "@asset-manager/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src"]
}
